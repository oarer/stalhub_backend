generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlayerRole {
  EXBO
  MEDIA
  SCAMMER
  STALHUB
  SPONSOR
  HELPER
  BUGBOUNTY
}

enum NotificationType {
  INFO
  WARN
  DANGER
}

enum AvatarSource {
  DISCORD
  TELEGRAM
  EXBO
}

enum StarTargetType {
  BUILD
  ARTICLE
}

enum ArticleStatus {
  PENDING
  REVIEW
  DENIED
  BANNED
}

// ================ USER MODEL ===================
model User {
  id       Int    @id @default(autoincrement())
  username String @unique @default("")
  name     String @default("") // display name

  sessions Sessions[]

  UserSettings UserSettings?

  joined_at DateTime @default(now())

  notifications Notifications[] @relation("Notifications")

  roles Role[]

  // Auth providers
  DiscordAuth  DiscordAuth?
  TelegramAuth TelegramAuth?
  EXBOAuth     EXBOAuth?

  badges UserBadges[]

  builds   Build[]
  articles Article[]
  stars    Star[]
}

model UserBadges {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]
}

model UserSettings {
  id     Int  @id @default(autoincrement())
  User   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int  @unique

  banned         Boolean   @default(false)
  ban_reason     String?
  ban_expires_at DateTime?

  public_profile Boolean      @default(false)
  avatar         AvatarSource?
}

model Sessions {
  id        Int    @id @default(autoincrement())
  sessionId String @unique @default("")

  User_Agent String @default("")
  ip         String @default("")
  User       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int

  last_used_at DateTime @default(now())
  revoked      Boolean  @default(false)
}

model Notifications {
  id         Int      @id @default(autoincrement())
  users      User[]   @relation("Notifications")
  content    String   @default("")
  author     String   @default("Система")
  type       Int      @default(0)
  created_at DateTime @default(now())
}

// ================ RBAC ===================
model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String       @default("")
  rank        Int          @default(0)

  users       User[]
  permissions Permission[]

  @@map("role")
}

model Permission {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String @default("")

  roles Role[]

  @@map("permission")
}

// ================ END RBAC ===================

// =================== AUTH PROVIDERS ===================

model DiscordAuth {
  id         Int     @id @default(autoincrement())
  discord_id String  @unique
  name       String
  username   String
  avatar_id  String?

  user   User @relation(fields: [userid], references: [id], onDelete: Cascade)
  userid Int  @unique

  connected_at DateTime @default(now())
}

model TelegramAuth {
  id          Int    @id @default(autoincrement())
  telegram_id String @unique

  name      String
  login     String?
  avatar_id String?

  user   User @relation(fields: [userid], references: [id], onDelete: Cascade)
  userid Int  @unique

  connected_at DateTime @default(now())
}

model EXBOAuth {
  id Int @id @default(autoincrement())

  exbo_id  String @unique
  login    String @default("")
  username String @default("")

  token_blob String

  access_expires_at  DateTime
  refresh_expires_at DateTime?

  user   User @relation(fields: [userid], references: [id], onDelete: Cascade)
  userid Int  @unique

  connected_at DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model EXBOAuthState {
  id String @id @default(cuid())

  state String @unique

  expires_at DateTime

  created_at DateTime @default(now())
}

// =============== END OF AUTH PROVIDERS ================

model Build {
  id          Int    @id @default(autoincrement())
  external_id String @unique

  title String
  data  String

  flags        Int     @default(0)
  accent_color String?
  tags         String  @default("")

  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("builds")
}

model Article {
  id            Int           @id @default(autoincrement())
  external_id   String        @unique
  status        ArticleStatus @default(PENDING)
  status_reason String?

  title   String
  content String

  flags        Int     @default(0)
  accent_color String?
  tags         String  @default("")

  author   User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId Int

  versions ArticleVersion[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("articles")
}

model ArticleVersion {
  id      Int    @id @default(autoincrement())
  version String
  content String

  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId Int

  created_at DateTime @default(now())

  @@map("article_versions")
}

model Star {
  id         Int            @id @default(autoincrement())
  targetType StarTargetType
  targetId   Int

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int

  created_at DateTime @default(now())

  @@unique([targetType, targetId, userId])
  @@map("stars")
}

// ================ END BUILDS/ARTICLES ===================

// ================ END OF USER MODEL ===================
model PlayerNote {
  id          String     @id @default(cuid())
  uuid        String     @unique
  role        PlayerRole @default(SCAMMER)
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model PopularPlayer {
  id        String   @id @default(cuid())
  uuid      String   @unique
  username  String
  alliance  String
  region    String
  views     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model PlayerBlacklist {
  id        String   @id @default(cuid())
  uuid      String   @unique
  createdAt DateTime @default(now())
}

// всё будет хорошо
