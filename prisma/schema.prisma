generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EXBO
  MEDIA
  SCAMMER
  STALHUB
  SPONSOR
  HELPER
  BUGBOUNTY
}

enum NotificationType {
  INFO
  WARN
  DANGER
}

model PlayerNote {
  id          String   @id @default(cuid())
  uuid        String   @unique
  role        Role     @default(SCAMMER)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PopularPlayer {
  id        String   @id @default(cuid())
  uuid      String   @unique
  username  String
  alliance  String
  region    String
  views     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model PlayerBlacklist {
  id        String   @id @default(cuid())
  uuid      String   @unique
  createdAt DateTime @default(now())
}

model Notification {
  id   Int              @id @default(autoincrement())
  type NotificationType @default(INFO)

  content String

  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([createdAt])
}
