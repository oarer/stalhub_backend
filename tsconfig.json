{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			]
		},
		"resolveJsonModule": true,
		"outDir": "./dist",
		"rootDir": "./",
		"types": [
			"bun-types"
		],
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"useDefineForClassFields": false
	}
}